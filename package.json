{
  "name": "b4best-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "sync-metadata": "node --experimental-vm-modules scripts/sync-metadata.js",
    "images:process": "node scripts/process-images.mjs",
    "images:dry-run": "node scripts/process-images.mjs --dry-run",
    "images:process:col": "node scripts/process-images.mjs --collection",
    "build:cf": "npx @cloudflare/next-on-pages",
    "preview": "wrangler pages dev .vercel/output/static",
    "deploy": "wrangler pages deploy .vercel/output/static",
    "db:migrate": "wrangler d1 execute be4best-db --file=../Be4Best-web/b4b/database/schema.sql",
    "db:seed": "wrangler d1 execute be4best-db --file=../Be4Best-web/b4b/database/seed.sql"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.0",
    "@hookform/resolvers": "^3.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "next": "^15.3.0",
    "next-intl": "^4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
