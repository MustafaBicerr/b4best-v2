# Cloudflare Pages _headers — applied to all responses from this Pages project.
# https://developers.cloudflare.com/pages/configuration/headers/

# Immutable static assets (content-hashed filenames — safe to cache forever)
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Next.js image optimisation endpoint
/_next/image*
  Cache-Control: public, max-age=2592000, s-maxage=31536000, stale-while-revalidate=86400

# Cloudflare Image Resizing responses (cdn-cgi/image)
/cdn-cgi/image/*
  Cache-Control: public, max-age=2592000, s-maxage=31536000, stale-while-revalidate=86400

# HTML pages — always revalidate so new deploys are picked up immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap & robots — cache for 1 day, revalidate in background
/sitemap.xml
  Cache-Control: public, max-age=86400, s-maxage=86400, stale-while-revalidate=3600

/robots.txt
  Cache-Control: public, max-age=86400, s-maxage=86400, stale-while-revalidate=3600

# Security headers applied globally
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
